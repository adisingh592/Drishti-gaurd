# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage
DATA_DIR=./data
MAX_UPLOAD_MB=10240

# Database (MongoDB) — leave empty to use local JSON store
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=drishti_guard

# AI
YOLO_MODEL=yolo11n.pt
# After Phase 1 training: point to trained weights
CUSTOM_MODEL_PATH=../ml/models/phase1/best.pt
WEAPON_MODEL_PATH=
WEAPON_WORLD_MODEL=yolov8s-worldv2.pt
WEAPON_CONFIDENCE_THRESHOLD=0.22
ENABLE_WEAPON_SCAN=true
DEVICE=cuda
SIMULATION_MODE=false
FRAME_SAMPLE_RATE=5
MAX_TRACKING_FRAMES=40
BATCH_SIZE=16
CONFIDENCE_THRESHOLD=0.45
USE_GPU=true
