# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage
DATA_DIR=./data
MAX_UPLOAD_MB=10240

# Database (MongoDB) — leave empty to use local JSON store
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=drishti_guard

# AI
YOLO_MODEL=yolo11n.pt
CUSTOM_MODEL_PATH=
DEVICE=cuda
FRAME_SAMPLE_RATE=2
BATCH_SIZE=16
CONFIDENCE_THRESHOLD=0.45
USE_GPU=true

# Analysis
SIMULATION_MODE=false
